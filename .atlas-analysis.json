  "keyFeatures": [
    "Interactive credential setup via QR code or manual Bot ID/Secret entry",
    "6 business categories: contact, msg, meeting, schedule, todo, doc",
    "AI Agent Skills for autonomous WeCom operations",
    "Cross-platform binary distribution via npm optional dependencies",
    "Encrypted local credential and MCP config storage",
    "Media file download with local path resolution",
    "JSON-RPC based tool invocation with dynamic schema discovery"
  ],
  "publicApiSurface": [
    "wecom-cli init",
    "wecom-cli contact <method> [json_args]",
    "wecom-cli msg <method> [json_args]",
    "wecom-cli meeting <method> [json_args]",
    "wecom-cli schedule <method> [json_args]",
    "wecom-cli todo <method> [json_args]",
    "wecom-cli doc <method> [json_args]",
    "contact get_userlist",
    "msg get_msg_chat_list",
    "msg get_message",
    "msg get_msg_media",
    "msg send_message",
    "todo create/read/update/delete",
    "meeting create/cancel/update/list",
    "schedule create/update/delete/list",
    "doc create_doc/read/write"
  ]
}
